# Environment Variables — ve-api

MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ve-admin
PORT=5000
NODE_ENV=development

# JWT Secrets — CHANGE IN PRODUCTION (use strong random strings)
JWT_ACCESS_SECRET=ve_admin_access_jwt_secret_change_me_in_production
JWT_REFRESH_SECRET=ve_admin_refresh_jwt_secret_change_me_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Resend Email — Add your API key here (if using Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=ve-admin <onboarding@resend.dev>

# SMTP Configuration — Alternative to Resend (e.g. Brevo, SendGrid, Gmail)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_FROM=
SMTP_PASS=

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:5173
